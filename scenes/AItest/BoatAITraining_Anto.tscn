[sub_resource type="GDScript" id="GDScript_dmd83"]
resource_name = "AIRayCastTraining"
script/source = "extends Node2D

@onready var boat: Boat = $Boat
@onready var boat_1: Boat = $Boat1
@onready var boat_2: Boat = $Boat2
@onready var boat_3: Boat = $Boat3

func _ready() -> void:
	boat.set_as_player_and_id(1)
	boat_1.set_as_player_and_id(1)
	boat_1.controller.control_mode = AIController2D.ControlModes.HUMAN
	boat.set_target(boat_1)
	boat_1.set_target(boat)
	
	boat_2.set_as_player_and_id(2)
	boat_3.set_as_player_and_id(2)
	boat_2.set_target(boat)
	boat_3.set_target(boat_1)
	
	boat.on_health_changed.connect(on_boat_hp_change)
	boat_1.on_health_changed.connect(on_boat_hp_change)
	boat_2.on_health_changed.connect(on_boat_hp_change)
	boat_3.on_health_changed.connect(on_boat_hp_change)
	set_boat_spawn2(boat, $spawner/spawn1)
	set_boat_spawn2(boat_1, $spawner/spawn1)
	set_boat_spawn2(boat_2, $spawner/spawn2)
	set_boat_spawn2(boat_2, $spawner/spawn2)
	
	
func on_boat_hp_change(newlife) :
	return
	if (boat.life <= 0) :
		var spawn = $spawner.get_random_point_forsp1()
		set_boat_spawn(boat, spawn)
	if (boat_1.life <= 0) :
		var spawn = $spawner.get_random_point_forsp1()
		set_boat_spawn(boat_1, spawn)
	if (boat_2.life <= 0) :
		var spawn = $spawner.get_random_point_forsp2()
		set_boat_spawn(boat_2, spawn)
	if (boat_3.life <= 0) :
		var spawn = $spawner.get_random_point_forsp2()
		set_boat_spawn(boat_3, spawn)
	pass
	
func set_boat_spawn(boat:Boat,spawn:Vector2) :
	boat.spawn_rectancgle.x = spawn.x
	boat.spawn_rectancgle.y = spawn.x
	boat.spawn_rectancgle.z = spawn.y
	boat.spawn_rectancgle.w = spawn.y

func set_boat_spawn2(boat, input : CollisionShape2D) :
	
	var rect_shape = input.shape as RectangleShape2D
	var half_width = rect_shape.size.x / 2.0
	var half_height = rect_shape.size.y / 2.0
	
	boat.spawn_rectancgle.x = -half_width + input.position.x
	boat.spawn_rectancgle.y = half_width + input.position.x
	boat.spawn_rectancgle.z = -half_height + input.position.y
	boat.spawn_rectancgle.w = half_height + input.position.y

var elapsed_time = 0
var change_wind_time = 1
func _process(delta: float) -> void:
	elapsed_time += delta
	if elapsed_time > change_wind_time :
		elapsed_time = 0
		var new_wind_dir = boat.wind_angle + randf_range(-0.1,0.1)
		boat.wind_angle = new_wind_dir
		boat_1.wind_angle = new_wind_dir
		boat_2.wind_angle = new_wind_dir
		boat_3.wind_angle = new_wind_dir
	if (boat and boat_1) :
		$Label.text = str(round(boat.controller.cumulated_rewar *100)/100)
		$Label2.text = str(round(boat_1.controller.cumulated_rewar *100)/100)
	
	if (boat_2 and boat_3) :
		$Label3.text = str(round(boat_2.controller.cumulated_rewar *100)/100)
		$Label4.text = str(round(boat_3.controller.cumulated_rewar *100)/100)
		
"

