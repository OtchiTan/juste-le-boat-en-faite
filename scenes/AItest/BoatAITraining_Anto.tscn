[sub_resource type="GDScript" id="GDScript_0wxyi"]
script/source = "extends StaticBody2D

class_name SpawnZone

@onready var spawn_1: CollisionShape2D = $spawn1
@onready var spawn_2: CollisionShape2D = $spawn2

func get_random_point_forsp1() -> Vector2:
	# On récupère la forme géométrique
	return get_random_point_in_shape(spawn_1)
	
func get_random_point_forsp2() -> Vector2:
	return get_random_point_in_shape(spawn_2)
	
func get_random_point_in_shape(collisionshape:CollisionShape2D) :
	var rect_shape = collisionshape.shape as RectangleShape2D
	var half_width = rect_shape.size.x / 2.0
	var half_height = rect_shape.size.y / 2.0
	
	# On tire un nombre au hasard entre les bords
	var rand_x = randf_range(-half_width, half_width)
	var rand_y = randf_range(-half_height, half_height)
	
	# On ajoute ce décalage à la position du centre de la zone
	return position + collisionshape.position + Vector2(rand_x, rand_y)
	
"

