[sub_resource type="GDScript" id="GDScript_dmd83"]
resource_name = "AIRayCastTraining"
script/source = "extends Node2D

@onready var boat: Boat = $Boat
@onready var boat_1: Boat = $Boat1
@onready var boat_2: Boat = $Boat2
@onready var boat_3: Boat = $Boat3
@onready var dummyboat: Boat = $Dummyboat

var wind_str :float= 1

var time_between_target = 45
var target_active_time = 30
var assign_target_timer : Timer
var delete_target_timer : Timer

func _ready() -> void:
	
	FactionManager.firendly_fire_on = false
	
	wind_str = randf() + 1 #multiplie l'accélération entre 1 et 2
	
	boat.set_as_player_and_id(1)
	boat_1.set_as_player_and_id(1)
	#boat_1.controller.control_mode = AIController2D.ControlModes.HUMAN

	boat_2.set_as_player_and_id(2)
	boat_3.set_as_player_and_id(2)
	boat_2.set_target(boat)
	boat_3.set_target(boat_1)
	boat.set_target(boat_2)
	boat_1.set_target(boat_3)
	
	boat.controller.reset_with_time = true
	boat_1.controller.reset_with_time = true
	boat_2.controller.reset_with_time = true
	boat_3.controller.reset_with_time = true
	
	set_boat_spawn2(boat, $spawner/spawn1)
	set_boat_spawn2(boat_1, $spawner/spawn1)
	set_boat_spawn2(boat_2, $spawner/spawn2)
	set_boat_spawn2(boat_2, $spawner/spawn2)
	
	
	boat.wind_strenght = wind_str
	boat_1.wind_strenght = wind_str
	boat_2.wind_strenght = wind_str
	boat_3.wind_strenght = wind_str
	
	
	assign_target_timer = Timer.new()
	assign_target_timer.one_shot = true
	assign_target_timer.wait_time = time_between_target
	assign_target_timer.timeout.connect(set_all_boat_target)
	add_child(assign_target_timer)
	
	delete_target_timer = Timer.new()
	delete_target_timer.one_shot = true
	delete_target_timer.wait_time = target_active_time
	delete_target_timer.timeout.connect(reset_targets)
	add_child(delete_target_timer)
	
	reset_targets()
	
	
	dummyboat.set_as_player_and_id(3)


func set_boat_spawn2(_boat, input : CollisionShape2D) :
	var rect_shape = input.shape as RectangleShape2D
	var half_width = rect_shape.size.x / 2.0
	var half_height = rect_shape.size.y / 2.0
	
	_boat.spawn_rectancgle.x = -half_width + input.position.x
	_boat.spawn_rectancgle.y = half_width + input.position.x
	_boat.spawn_rectancgle.z = -half_height + input.position.y
	_boat.spawn_rectancgle.w = half_height + input.position.y

var elapsed_time_since_wind_changed = 0
var change_wind_time = 1


func _process(delta: float) -> void:
	elapsed_time_since_wind_changed += delta
	if elapsed_time_since_wind_changed > change_wind_time :
		elapsed_time_since_wind_changed = 0
		var new_wind_dir = boat.wind_angle + randf_range(-0.05,0.05)
		$WindNode.global_rotation = new_wind_dir
		boat.wind_angle = new_wind_dir
		boat_1.wind_angle = new_wind_dir
		boat_2.wind_angle = new_wind_dir
		boat_3.wind_angle = new_wind_dir
		dummyboat.wind_angle =new_wind_dir
	
	if (boat and boat_1) :
		$Label.text = str(round(boat.controller.cumulated_rewar *100)/100)
		$Label2.text = str(round(boat_1.controller.cumulated_rewar *100)/100)
	
	if (boat_2 and boat_3) :
		$Label3.text = str(round(boat_2.controller.cumulated_rewar *100)/100)
		$Label4.text = str(round(boat_3.controller.cumulated_rewar *100)/100)
		
@onready var target_1_sprite: Sprite2D = $targeting/target1
@onready var target_2_sprite: Sprite2D = $targeting/target2

func reset_targets() :
	assign_target_timer.start()
	target_1_sprite.visible = false
	target_2_sprite.visible = false
	boat.controller.b_goto_target = 0
	boat_1.controller.b_goto_target = 0
	boat_2.controller.b_goto_target = 0
	boat_3.controller.b_goto_target = 0

func set_all_boat_target() :
	delete_target_timer.start()
	var target1 = $targeting.get_random_point_forsp1()
	set_boat_target(boat,target1)
	set_boat_target(boat_1,target1)
	
	var target2 = $targeting.get_random_point_forsp2()
	set_boat_target(boat_2,target2)
	set_boat_target(boat_3,target2)
	
	target_1_sprite.visible = true
	target_2_sprite.visible = true
	target_1_sprite.position = target1
	target_2_sprite.position = target2
	
func set_boat_target(_boat : Boat, target : Vector2) :
	_boat.controller.target_point = target
	_boat.controller.b_goto_target =1
"

