[sub_resource type="GDScript" id="GDScript_ubajb"]
resource_name = "DummyBoatController"
script/source = "extends Node

@onready var boat: Boat = $\"..\"

var needs_reset = false

var is_immobile := false
var state_timer: Timer

# Variables pour éviter la \"convulsion\" (Jitter)
var target_throttle := 0.0
var target_steering := 0.0
var random_direction_timer := 0.0

func _ready():
	boat.controller = self
	# --- LE TIMER DE CYCLE (10s on / 10s off) ---
	state_timer = Timer.new()
	state_timer.wait_time = 10.0
	state_timer.autostart = true
	state_timer.timeout.connect(_on_state_timer_timeout)
	add_child(state_timer)

func _on_state_timer_timeout():
	# À chaque fois que le timer de 10s sonne, on inverse l'état
	is_immobile = !is_immobile
	
	if is_immobile:
		target_throttle = 0.0
		target_steering = 0.0
		boat.throttle = 0.0
		boat.steering = 0.0

func update(delta):
	if (needs_reset) : 
		boat.reset()
		needs_reset = false
	
	if is_immobile:
		boat.throttle = 0.0
		boat.steering = 0.0
		return
		
	random_direction_timer -= delta
	if random_direction_timer <= 0.0:
		# randf_range donne un float entre -1.0 et 1.0
		target_throttle = randf_range(-1.0, 1.0)
		target_steering = randf_range(-1.0, 1.0)
		
		# On relance le petit chrono interne (ex: il garde ce cap pendant 1.5 à 3 secondes)
		random_direction_timer = randf_range(1.5, 3.0)
		
	# 3. Lissage (Lerp) pour que le bateau ne tourne pas de façon robotique et instantanée
	boat.throttle = lerp(boat.throttle, target_throttle, 2.0 * delta)
	boat.steering = lerp(boat.steering, target_steering, 2.0 * delta)
"

