[ext_resource type="Script" uid="uid://ok2c2172j67q" path="res://addons/godot_rl_agents/sync.gd" id="3_etidm"]
[ext_resource type="PackedScene" uid="uid://bd3bhg5ddf81h" path="res://scenes/Boat.tscn" id="3_votaf"]

[sub_resource type="GDScript" id="GDScript_etidm"]
script/source = "extends Node2D

@export var boat_scene: PackedScene
@export var label_1: Label
@export var label_2: Label

var boat1 : Boat = null
var boat2 : Boat = null

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	boat1 = boat_scene.instantiate()
	boat1.position = Vector2(-500,200)
	boat1.set_as_player_and_id(1)
	add_child(boat1)
	boat2 = boat_scene.instantiate()
	boat2.position = Vector2(500,-200)
	boat2.rotation = PI
	boat2.set_as_player_and_id(2)
	add_child(boat2)

	boat1.set_target(boat2)
	boat2.set_target(boat1)


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	label_1.text = \"|reward : \"
	label_1.text += str(boat1.controller.reward)
	label_1.text += \"\\n|delta_dist : \"
	label_1.text += str(boat1.controller.delta_dist)
	label_1.text += \"\\n|delta_angle : \"
	label_1.text += str(boat1.controller.delta_angle)
	label_1.text += \"\\n|self_speed : \"
	label_1.text += str(boat1.controller.self_speed)
	label_1.text += \"\\n|target_rotation : \"
	label_1.text += str(boat1.controller.target_rotation)
	label_1.text += \"\\n|target_speed : \"
	label_1.text += str(boat1.controller.target_speed)
	label_2.text = str(boat2.controller.reward)
"

[sub_resource type="LabelSettings" id="LabelSettings_etidm"]
font_size = 30

[node name="BoatTraining" type="Node2D" unique_id=742048777 node_paths=PackedStringArray("label_1", "label_2")]
